# PayPlan UAT – do not commit real values. Copy to .env and fill.
# For CI, set these as GitHub Secrets.

# Required for admin smoke (local): your UAT admin creds + base URL (never commit real values)
BASE_URL=https://uat.payplan.ai
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional: override paths (defaults in code)
ADMIN_LOGIN_PATH=/platform/admin/login
MANAGE_TENANTS_PATH=/platform/admin/manage-tenants

# Required for Patria tests (and in CI). Optional locally (Patria tests skipped if unset).
API_BASE_URL=https://uat-api.payplan.ai
UI_AUTOMATION_KEY=
